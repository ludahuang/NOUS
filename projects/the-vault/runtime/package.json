    "enrich:psychology-wikipedia": "node scripts/enrich-psychology-wikipedia.mjs",
    "capture:agent-docs": "node scripts/capture-agent-docs.mjs",
    "dev:alpha": "npm run dev --workspace @the-vault/web",
