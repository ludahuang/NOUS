{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nous.we-media.net/schemas/nous-entity.schema.json",
  "title": "NOUS Entity",
  "type": "object",
  "required": ["id", "type", "name", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^nous(:[a-z0-9][a-z0-9-]*)+$"
    },
    "type": {
      "type": "string",
      "enum": [
        "person",
        "organization",
        "space",
        "exhibition",
        "agent",
        "project",
        "collection",
        "work",
        "source",
        "event",
        "curatorial-system"
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "alternate_names": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "rights": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "reference": {
      "type": "object",
      "required": ["ref"],
      "properties": {
        "ref": {
          "type": "string",
          "pattern": "^nous(:[a-z0-9][a-z0-9-]*)+$"
        }
      },
      "additionalProperties": false
    }
  }
}
